{
  "type": "passport",
  "name": "Паспорт РФ",
  "aliases": ["паспорт", "паспорт рф", "passport rf"],
  "recognitionFeatures": [
    "разворот паспорта гражданина РФ",
    "фотография владельца",
    "серия и номер паспорта",
    "дата рождения",
    "код подразделения",
    "орган выдачи"
  ],
  "firstPassFields": [
    {
      "id": "series",
      "label": "Серия",
      "type": "string",
      "required": true,
      "normalization": ["digits-only", "length:4"]
    },
    {
      "id": "number",
      "label": "Номер",
      "type": "string",
      "required": true,
      "normalization": ["digits-only", "length:6"]
    },
    {
      "id": "birth_date",
      "label": "Дата рождения",
      "type": "date",
      "required": true,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
    }
  ],
  "secondPassFields": [
    {
      "id": "full_name",
      "label": "ФИО владельца",
      "type": "string",
      "required": true
    },
    {
      "id": "birth_place",
      "label": "Место рождения",
      "type": "string",
      "required": false
    },
    {
      "id": "issue_date",
      "label": "Дата выдачи",
      "type": "date",
      "required": false,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
    },
    {
      "id": "issuing_authority",
      "label": "Орган выдачи",
      "type": "string",
      "required": false
    },
    {
      "id": "subdivision_code",
      "label": "Код подразделения",
      "type": "string",
      "required": false
    },
    {
      "id": "registration_address",
      "label": "Адрес регистрации",
      "type": "string",
      "required": false
    }
  ],
  "validationRules": [
    "series должен содержать ровно 4 цифры",
    "number должен содержать ровно 6 цифр",
    "birth_date должен быть корректной датой в формате YYYY-MM-DD"
  ],
  "secondPass": {
    "mode": "free-legal"
  },
  "targetSchema": "passport",
  "crmNaming": {
    "template": "passport_{series}{number}_{createdAtDate}_{counter}",
    "keyFields": ["series", "number"]
  }
}
