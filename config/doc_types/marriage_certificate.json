    "номер актовой записи"
  ],
  "firstPassFields": [
    {
      "id": "record_number",
      "label": "Номер актовой записи",
      "type": "string",
      "required": true
    },
    {
      "id": "marriage_date",
      "label": "Дата заключения брака",
      "type": "date",
      "required": true,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
    },
    {
      "id": "husband_surname",
      "label": "Фамилия супруга",
      "type": "string",
      "required": true
    }
  ],
  "secondPassFields": [
    {
      "id": "wife_surname",
      "label": "Фамилия супруги",
      "type": "string",
      "required": true
    },
    {
      "id": "husband_full_name",
      "label": "ФИО супруга",
      "type": "string",
      "required": false
    },
    {
      "id": "wife_full_name",
      "label": "ФИО супруги",
      "type": "string",
      "required": false
    },
    {
      "id": "registry_office",
      "label": "Орган ЗАГС",
      "type": "string",
      "required": false
    },
    {
      "id": "record_date",
      "label": "Дата актовой записи",
      "type": "date",
      "required": false,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
