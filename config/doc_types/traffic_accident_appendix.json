{
  "type": "traffic_accident_appendix",
  "name": "Приложение к постановлению об административном правонарушении",
  "aliases": [
    "приложение к постановлению",
    "административное правонарушение",
    "дтп",
    "приложение к постановлению об административном правонарушении"
  ],
  "recognitionFeatures": [
    "упоминание административного правонарушения",
    "номер постановления",
    "статья КоАП",
    "дата и время ДТП",
    "место ДТП",
    "водители",
    "транспортные средства",
    "повреждения",
    "инспектор",
    "подразделение ГИБДД"
  ],
  "firstPassFields": [
    {
      "id": "document_number",
      "label": "Номер постановления",
      "type": "string",
      "required": true
    },
    {
      "id": "accident_date",
      "label": "Дата ДТП",
      "type": "date",
      "required": true,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
    },
    {
      "id": "accident_time",
      "label": "Время ДТП",
      "type": "time",
      "required": false
    }
  ],
  "secondPassFields": [
    {
      "id": "article",
      "label": "Статья КоАП",
      "type": "string",
      "required": true
    },
    {
      "id": "violation_code",
      "label": "Код нарушения",
      "type": "string",
      "required": false
    },
    {
      "id": "location",
      "label": "Место ДТП",
      "type": "string",
      "required": true
    },
    {
      "id": "drivers",
      "label": "Водители",
      "type": "array",
      "required": true
    },
    {
      "id": "vehicles",
      "label": "Транспортные средства",
      "type": "array",
      "required": true
    },
    {
      "id": "damage",
      "label": "Повреждения",
      "type": "array",
      "required": false
    },
    {
      "id": "inspector",
      "label": "Инспектор",
      "type": "string",
      "required": false
    },
    {
      "id": "traffic_police_unit",
      "label": "Подразделение ГИБДД",
      "type": "string",
      "required": false
    }
  ],
  "validationRules": [
    "article не должен быть пустым",
    "accident_date должен быть корректной датой в формате YYYY-MM-DD",
    "drivers и vehicles, если указаны, должны быть массивами"
  ],
  "secondPass": {
    "mode": "free-legal"
  },
  "targetSchema": "traffic_accident_appendix",
  "crmNaming": {
    "template": "traffic_accident_{document_number}_{createdAtDate}_{counter}",
    "keyFields": ["document_number"]
  }
}
