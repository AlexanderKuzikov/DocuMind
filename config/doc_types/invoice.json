{
  "type": "invoice",
  "name": "Счёт",
  "aliases": ["счёт", "счет", "инвойс", "invoice"],
  "recognitionFeatures": [
    "номер счёта",
    "дата счёта",
    "поставщик",
    "покупатель",
    "итоговая сумма",
    "валюта"
  ],
  "firstPassFields": [
    {
      "id": "invoice_number",
      "label": "Номер счёта",
      "type": "string",
      "required": true
    },
    {
      "id": "invoice_date",
      "label": "Дата счёта",
      "type": "date",
      "required": true,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
    },
    {
      "id": "supplier_name",
      "label": "Поставщик",
      "type": "string",
      "required": true
    }
  ],
  "secondPassFields": [
    {
      "id": "buyer_name",
      "label": "Покупатель",
      "type": "string",
      "required": true
    },
    {
      "id": "buyer_inn",
      "label": "ИНН покупателя",
      "type": "string",
      "required": false,
      "normalization": ["digits-only", "length:10", "length:12"]
    },
    {
      "id": "supplier_inn",
      "label": "ИНН поставщика",
      "type": "string",
      "required": false,
      "normalization": ["digits-only", "length:10", "length:12"]
    },
    {
      "id": "invoice_total",
      "label": "Итоговая сумма",
      "type": "number",
      "required": true
    },
    {
      "id": "currency",
      "label": "Валюта",
      "type": "string",
      "required": false,
      "normalization": ["uppercase"]
    },
    {
      "id": "payment_due_date",
      "label": "Срок оплаты",
      "type": "date",
      "required": false,
      "format": "DD.MM.YYYY",
      "outputFormat": "YYYY-MM-DD"
    }
  ],
  "validationRules": [
    "invoice_total должен быть неотрицательным числом",
    "currency должен быть ISO-кодом валюты, если указан",
    "invoice_date и payment_due_date должны быть корректными датами в формате YYYY-MM-DD"
  ],
  "secondPass": {
    "mode": "free-legal"
  },
  "targetSchema": "invoice",
  "crmNaming": {
    "template": "invoice_{invoice_number}_{createdAtDate}_{counter}",
    "keyFields": ["invoice_number"]
  }
}
