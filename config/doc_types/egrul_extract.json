      "required": true,
      "normalization": ["date"],
      "extractionHint": "Дата внесения записи, содержащей указанные сведения. Не дата выписки."
    },
    {
      "id": "short_name_ru",
      "label": "Сокращённое наименование на русском языке",
      "type": "string",
      "required": true,
      "normalization": ["trim"],
      "extractionHint": "Например: ООО «Название» или ООО \"Название\"."
    }
  ],
  "firstPassFields": [
    {
      "id": "ogrn",
      "label": "ОГРН",
      "type": "string",
      "required": true,
