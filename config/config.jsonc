{
  // DocuMind MVP configuration.
  // This file is JSONC so comments are allowed for humans.
  "schemaVersion": "0.1.0",
  "paths": {
    "input": "../input",
    "staging": "../staging",
    "output": "../output",
    "debug": "../debug",
    "docTypes": "./doc_types",
    "prompts": "./prompts"
  },
  "rasterize": {
    "page": "first",
    "dpi": 200,
    "quality": 90,
    "lossless": false,
    "format": "webp"
  },
  "processing": {
    "concurrency": 1,
    "maxDocumentsPerRun": 1,
    "allowParallelDocuments": false,
    "allowParallelLlmCalls": false
  },
  "llm": {
    // Default profile for current local experiments with LM Studio.
    // LM Studio OpenAI-compatible server does not require an API key.
    "activeProfile": "local-lmstudio",
    "imagePolicy": "session",
    "sessionFallback": "each-pass",
    "temperature": 0,
    "thinking": {
      "enabled": false,
      "effort": "medium"
    },
    "profiles": {
      "mvp-routerai": {
        "baseUrl": "https://routerai.ru/v1",
        "model": "qwen/qwen3.6-35b-a3b",
        "apiKeyEnv": "ROUTERAI_API_KEY",
        "imageEncoding": "base64-prefixed",
        "timeout": 180000,
        "stream": false
      },
      "local-lmstudio": {
        "baseUrl": "http://127.0.0.1:1234/v1",
        "model": "qwen3.6:35b-a3b",
        "apiKeyEnv": null,
        // LM Studio rejects data-url format; use base64-prefixed
        "imageEncoding": "base64-prefixed",
        "timeout": 300000,
        "stream": false
      },
      "prod-ollama": {
        "baseUrl": "http://127.0.0.1:11434/v1",
        "model": "qwen3.6:35b-a3b",
        "apiKeyEnv": null,
        // Ollama OpenAI-compatible server; base64-prefixed for consistency with LM Studio
        "imageEncoding": "base64-prefixed",
        "timeout": 300000,
        "stream": false
      }
    }
  },
  "extraction": {
    "secondPassMode": "free-legal",
    "universalFields": [
      "document_number",
      "document_date",
      "counterparty_name"
    ]
  },
  "validation": {
    "deterministic": true,
    "llm": {
      "enabled": false,
      "profile": "local-lmstudio",
      "temperature": 0,
      "timeout": 120000
    }
  },
  "debug": {
    "enabled": true,
    "saveRenderedPrompts": true,
    "saveModelResponses": true,
    "saveArtifacts": true
  },
  "components": {
    "dir": "../src/components"
  },
  "ui": {
    "host": "127.0.0.1",
    "defaultPort": 4173,
    "portRangeEnd": 4183
  },
  "pipeline": [
    {
      "id": "discoverDocuments",
      "component": "discover-documents",
      "enabled": true,
      "required": true
    },
    {
      "id": "rasterizeFirstPage",
      "component": "rasterize-first-page",
      "enabled": true,
      "required": true
    },
    {
      "id": "buildUniversalPrompt",
      "component": "build-universal-prompt",
      "enabled": true,
      "required": true
    },
    {
      "id": "llmUniversalPass",
      "component": "llm-universal-pass",
      "enabled": true,
      "required": true
    },
    {
      "id": "buildSpecificPrompt",
      "component": "build-specific-prompt",
      "enabled": true,
      "required": true
    },
    {
      "id": "llmSpecificPass",
      "component": "llm-specific-pass",
      "enabled": true,
      "required": true
    },
    {
      "id": "normalizeFields",
      "component": "normalize-fields",
      "enabled": true,
      "required": true
    },
    {
      "id": "writeOutput",
      "component": "write-output",
      "enabled": true,
      "required": true
    }
  ]
}
